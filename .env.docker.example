# Mirror dari conf/app.conf — isi .env.docker dengan nilai yang sama saat deploy Docker.
# Saat container jalan, scripts/entrypoint.sh menulis ulang nilai ini ke conf/app.conf di dalam image.
#
# Keamanan: jangan commit .env.docker. Kalau SMTP/password pernah ter-commit ke git, "rotate" artinya
# buat password/app password baru di penyedia (mis. Gmail App Password baru), lalu pakai yang baru.

# --- app (setara httpport, runmode di app.conf) ---
APP_HTTP_PORT=112
APP_RUNMODE=prod

# --- Database (setara db_* di app.conf; di compose DB_HOST otomatis "db") ---
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=psikologi_db
DB_SSLMODE=disable

# --- Email SMTP (setara SMTP_*, FROM_* di app.conf) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=
FROM_NAME=Psychee Wellness

# --- Admin seed (admin_email / admin_password; bisa ditambah di app.conf untuk lokal) ---
ADMIN_EMAIL=admin@psikologi.local
ADMIN_PASSWORD=

# --- Link publik app (BASE_URL; disarankan URL production, mis. https://domain.com) ---
BASE_URL=http://localhost:112

# --- otomasi startup ---
AUTO_MIGRATE=true
AUTO_SEED_ADMIN=false
